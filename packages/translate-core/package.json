{
  "name": "@lazytrans/translate-core",
  "version": "0.1.0",
  "description": "LazyTrans translation core library",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./translate/types": {
      "types": "./dist/translate/types.d.mts",
      "import": "./dist/translate/types.mjs",
      "require": "./dist/translate/types.cjs"
    },
    "./tts/types": {
      "types": "./dist/tts/types.d.mts",
      "import": "./dist/tts/types.mjs",
      "require": "./dist/tts/types.cjs"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lazytrans/lazytrans",
    "directory": "packages/translate-core"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "tsdown": "^0.21.0",
    "typescript": "~5.9.3"
  }
}
