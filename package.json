{
  "name": "@lazytrans/monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bunx turbo run dev",
    "dev:desktop": "bun run --cwd apps/desktop tauri:dev",
    "build": "bunx turbo run build",
    "build:desktop": "bunx turbo run build --filter=@lazytrans/desktop",
    "typecheck": "bunx turbo run typecheck",
    "check": "bun run typecheck",
    "lint": "bunx ultracite check .",
    "fix": "bunx ultracite fix",
    "check-fix": "bun run check && bun run fix",
    "test": "bunx turbo run test",
    "clean": "bunx turbo run clean"
  },
  "devDependencies": {
    "@lazytrans/typescript-config": "workspace:*",
    "turbo": "^2.9.12",
    "@changesets/cli": "^2.31.0",
    "typescript": "~6.0.3"
  }
}
